<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Member Directory" android:textSize="24sp" android:textStyle="bold" android:textColor="#E65100"/>
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Sanatani Bandhan CRM" android:textSize="14sp" android:textColor="#757575" android:layout_marginBottom="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnGoToAdd" android:layout_width="0dp" android:layout_height="55dp"
            android:layout_weight="1" android:text="+ Add New" android:backgroundTint="#1976D2" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnSharePdf" android:layout_width="0dp" android:layout_height="55dp"
            android:layout_weight="1" android:text="Share PDF" android:backgroundTint="#388E3C" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <EditText android:id="@+id/searchBar" android:layout_width="match_parent" android:layout_height="50dp"
        android:hint="Search by Name or SB-ID..." android:background="#FFFFFF" android:paddingHorizontal="16dp" android:elevation="2dp" android:layout_marginBottom="16dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:id="@+id/membersContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
