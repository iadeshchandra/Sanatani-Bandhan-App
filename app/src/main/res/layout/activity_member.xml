<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" 
    android:layout_height="match_parent"
    android:orientation="vertical" 
    android:background="#FAF9F6" 
    android:padding="16dp">

    <TextView 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content"
        android:text="👥 Member Directory" 
        android:textSize="26sp" 
        android:textStyle="bold"
        android:textColor="#212121" 
        android:layout_marginBottom="4dp"/>

    <TextView 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content"
        android:text="Sanatani Bandhan CRM" 
        android:textSize="14sp" 
        android:textColor="#757575" 
        android:layout_marginBottom="4dp"/>

    <!-- ✨ NEW: Proactive Upgrade UI Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView 
            android:id="@+id/tvPlanStatus"
            android:layout_width="0dp" 
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Loading Quota..." 
            android:textSize="14sp" 
            android:textStyle="bold"
            android:textColor="#E65100"/>

        <Button
            android:id="@+id/btnProactiveUpgrade"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⭐ UPGRADE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            app:cornerRadius="6dp"
            android:paddingHorizontal="12dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone"/> <!-- Hidden by default, shown only for free users -->
    </LinearLayout>

    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:orientation="horizontal" 
        android:weightSum="2" 
        android:layout_marginBottom="16dp">
        
        <Button 
            android:id="@+id/btnAddNew" 
            android:layout_width="0dp" 
            android:layout_weight="1" 
            android:layout_height="55dp"
            android:text="+ ADD NEW" 
            android:backgroundTint="#1976D2" 
            android:layout_marginEnd="6dp"/>

        <Button 
            android:id="@+id/btnSharePdf" 
            android:layout_width="0dp" 
            android:layout_weight="1" 
            android:layout_height="55dp"
            android:text="SHARE PDF" 
            android:backgroundTint="#388E3C" 
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <AutoCompleteTextView 
        android:id="@+id/inputSearch" 
        android:layout_width="match_parent" 
        android:layout_height="55dp"
        android:hint="Search by Name or SB-ID..." 
        android:background="#FFFFFF" 
        android:padding="12dp" 
        android:layout_marginBottom="16dp" 
        android:completionThreshold="1"/>

    <ScrollView 
        android:layout_width="match_parent" 
        android:layout_height="match_parent">
        <LinearLayout 
            android:id="@+id/membersContainer" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
