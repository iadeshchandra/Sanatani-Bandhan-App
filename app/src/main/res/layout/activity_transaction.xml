<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFBF2"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Chanda Ledger"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvTotalDonations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Collected: ৳0.0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnAddDonation"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minHeight="55dp"
            android:text="+ RECORD"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnExportMaster"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minHeight="55dp"
            android:text="MASTER PDF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#455A64"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/inputSearch"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="55dp"
            android:hint="Search Donor..."
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnFilterDates"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:text="📅 FILTER"
            android:backgroundTint="#F57C00"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/donationsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
