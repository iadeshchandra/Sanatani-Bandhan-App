<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Smart Chanda Ledger" android:textSize="26sp" android:textStyle="bold"
        android:textColor="#212121" android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tvTotalDonations" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Total Collected: ৳0.0" android:textSize="18sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnAddTransaction" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp"
            android:text="+ RECORD CHANDA" android:backgroundTint="#2E7D32" android:layout_marginEnd="6dp"/>
        <Button android:id="@+id/btnExportMaster" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp"
            android:text="MASTER PDF" android:backgroundTint="#455A64" android:layout_marginStart="6dp"/>
    </LinearLayout>

    <EditText android:id="@+id/inputSearch" android:layout_width="match_parent" android:layout_height="55dp"
        android:hint="Search Donor Name..." android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="16dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:id="@+id/transactionsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
