<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Mandir Event Calendar" android:textSize="26sp" android:textStyle="bold"
        android:textColor="#7B1FA2" android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnAddEvent" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="+ Schedule New Event/Puja" android:backgroundTint="#7B1FA2" android:layout_marginBottom="16dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:id="@+id/eventsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
