<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FAF9F6">
    
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Register Member" android:textSize="26sp" android:textStyle="bold" android:textColor="#E65100" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Required Information" android:textStyle="bold" android:textColor="#757575" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/inputName" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Full Name *" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <EditText android:id="@+id/inputPhone" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Phone Number *" android:inputType="phone" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        
        <EditText android:id="@+id/inputGotra" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Gotra *" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <EditText android:id="@+id/inputBloodGroup" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Blood Group *" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="24dp" android:elevation="2dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Optional KYC Details" android:textStyle="bold" android:textColor="#757575" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/inputFather" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Father's Name" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <EditText android:id="@+id/inputMother" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Mother's Name" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <EditText android:id="@+id/inputNid" android:layout_width="match_parent" android:layout_height="55dp" android:hint="NID Number" android:inputType="number" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <EditText android:id="@+id/inputAddress" android:layout_width="match_parent" android:layout_height="80dp" android:hint="Full Address" android:gravity="top|start" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="24dp" android:elevation="2dp"/>

        <Button android:id="@+id/btnSaveMember" android:layout_width="match_parent" android:layout_height="60dp" android:text="Create Member Profile" android:backgroundTint="#E65100" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
