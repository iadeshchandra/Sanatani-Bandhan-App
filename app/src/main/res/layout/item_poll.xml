<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="16dp" app:cardCornerRadius="12dp"
    app:cardElevation="4dp" app:cardBackgroundColor="#E3F2FD"> <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/tvPollQuestion" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:textColor="#0D47A1"/>
        <TextView android:id="@+id/tvLiveCounts" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#1565C0" android:layout_marginTop="8dp" android:textStyle="bold"/>
        
        <TextView android:id="@+id/tvOfficialComment" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#424242" android:textStyle="italic" android:layout_marginTop="8dp" android:visibility="gone" android:padding="8dp" android:background="#BBDEFB"/>

        <LinearLayout android:id="@+id/layoutVoting" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp" android:weightSum="2">
            <Button android:id="@+id/btnOptionA" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:backgroundTint="#1976D2"/>
            <Button android:id="@+id/btnOptionB" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:backgroundTint="#F57C00"/>
        </LinearLayout>

        <TextView android:id="@+id/tvPollStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#2E7D32" android:textStyle="bold" android:layout_marginTop="12dp" android:visibility="gone" android:gravity="center"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp">
            <Button android:id="@+id/btnAddComment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Remark" android:textSize="10sp" android:backgroundTint="#757575" android:visibility="gone" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnDownloadPollData" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Download Insight PDF" android:textSize="11sp" android:backgroundTint="#0D47A1"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
