<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    app:cardCornerRadius="12dp" app:cardElevation="3dp" android:layout_marginBottom="16dp"
    app:strokeWidth="1dp" app:strokeColor="#FFCC80"
    app:cardBackgroundColor="#FFFBF2"> <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:id="@+id/tvPollStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:background="#E8F5E9" android:textColor="#2E7D32"/>
            <TextView android:id="@+id/tvPollCreator" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#757575" android:gravity="end" android:textStyle="italic"/>
        </LinearLayout>

        <TextView android:id="@+id/tvPollCountdown" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#E65100" android:textStyle="bold" android:layout_marginBottom="10dp"/>

        <TextView android:id="@+id/tvPollQuestion" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:textColor="#212121" android:layout_marginBottom="12dp"/>
        
        <LinearLayout android:id="@+id/pollOptionsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="12dp"/>
        
        <TextView android:id="@+id/tvPollAdminComment" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#455A64" android:textStyle="italic" android:layout_marginBottom="12dp" android:visibility="gone"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
            <Button android:id="@+id/btnVote" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="50dp" android:text="CAST VOTE" android:backgroundTint="#E65100" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnDownloadPollPdf" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="50dp" android:text="PDF INSIGHT" android:backgroundTint="#455A64" android:layout_marginStart="4dp"/>
        </LinearLayout>
        
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
