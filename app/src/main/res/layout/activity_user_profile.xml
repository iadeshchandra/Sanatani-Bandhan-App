<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#FFFBF2">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="My Swadharma Profile" android:textSize="26sp" android:textStyle="bold" android:textColor="#212121" android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:cardElevation="3dp" android:layout_marginBottom="24dp" app:cardBackgroundColor="#E8F5E9">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Identity Locked by Mandir" android:textSize="12sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvMyName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121"/>
                <TextView android:id="@+id/tvMyId" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#1976D2" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvMyDonated" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#2E7D32" android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Editable Information" android:textSize="16sp" android:textStyle="bold" android:textColor="#E65100" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/inputMyPhone" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Phone Number" android:inputType="phone" android:background="#FFFFFF" android:elevation="2dp" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <EditText android:id="@+id/inputMyGotra" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Gotra (Lineage)" android:background="#FFFFFF" android:elevation="2dp" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <EditText android:id="@+id/inputMyBlood" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Blood Group" android:background="#FFFFFF" android:elevation="2dp" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <EditText android:id="@+id/inputMyAddress" android:layout_width="match_parent" android:layout_height="80dp" android:hint="Full Address" android:background="#FFFFFF" android:elevation="2dp" android:padding="12dp" android:gravity="top" android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btnUpdateProfile" android:layout_width="match_parent" android:layout_height="60dp" android:text="💾 UPDATE MY PROFILE" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#2E7D32" android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
