<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp" android:background="#FAF9F6">
    
    <TextView android:text="Record Transaction" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="20dp"/>

    <Spinner android:id="@+id/typeSpinner" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="16dp" android:entries="@array/transaction_types"/>

    <EditText android:id="@+id/inputTitle" android:layout_width="match_parent" android:layout_height="60dp" android:hint="Name / Expense Title" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="16dp"/>
    
    <EditText android:id="@+id/inputAmount" android:layout_width="match_parent" android:layout_height="60dp" android:hint="Amount (৳)" android:inputType="numberDecimal" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="60dp" android:text="Save Record" android:backgroundTint="#FF9800"/>
</LinearLayout>
