<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="20dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Record Smart Chanda" android:textSize="22sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:cardCornerRadius="16dp" app:cardElevation="4dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <RadioGroup android:id="@+id/radioGroupType" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <RadioButton android:id="@+id/radioMember" android:layout_width="wrap_content" android:layout_height="wrap_content" 
                    android:text="Registered Member" android:checked="true" android:buttonTint="#FF9800"/>
                <RadioButton android:id="@+id/radioGuest" android:layout_width="wrap_content" android:layout_height="wrap_content" 
                    android:text="Guest Donor" android:layout_marginStart="16dp" android:buttonTint="#FF9800"/>
            </RadioGroup>

            <AutoCompleteTextView android:id="@+id/autoCompleteMember" android:layout_width="match_parent" android:layout_height="60dp"
                android:hint="Search Name or SB-ID..." android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="1dp" android:completionThreshold="1"/>

            <EditText android:id="@+id/inputGuestName" android:layout_width="match_parent" android:layout_height="60dp"
                android:hint="Guest Full Name" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="1dp" android:visibility="gone"/>

            <EditText android:id="@+id/inputAmount" android:layout_width="match_parent" android:layout_height="60dp"
                android:hint="Amount (৳)" android:inputType="numberDecimal" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp" android:elevation="1dp"/>

            <EditText android:id="@+id/inputNote" android:layout_width="match_parent" android:layout_height="60dp"
                android:hint="Note (e.g. Saraswati Puja Chanda)" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="24dp" android:elevation="1dp"/>

            <Button android:id="@+id/btnSaveTransaction" android:layout_width="match_parent" android:layout_height="60dp"
                android:text="Log Chanda &amp; Update Total" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#2E7D32"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
