<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Sanatani Panchayat" android:textSize="26sp" android:textStyle="bold"
        android:textColor="#1976D2" android:layout_marginBottom="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
        <Button android:id="@+id/btnCreatePoll" android:layout_width="0dp" android:layout_weight="1" android:layout_height="60dp"
            android:text="+ New Poll" android:backgroundTint="#1976D2" android:visibility="gone" android:layout_marginEnd="8dp"/>
        
        <Button android:id="@+id/btnExportAllPolls" android:layout_width="0dp" android:layout_weight="1" android:layout_height="60dp"
            android:text="Export PDF" android:backgroundTint="#37474F" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="16dp">
        <LinearLayout android:id="@+id/pollsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
