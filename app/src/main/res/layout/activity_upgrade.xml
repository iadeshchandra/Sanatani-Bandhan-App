<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0" > <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌟 Upgrade to Premium"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlock unlimited Devotees, Master PDFs, and Mass WhatsApp Broadcasts for your Mandir.\n\nDakshina: ৳500 / Month"
            android:textSize="16sp"
            android:textAlignment="center"
            android:textColor="#424242"
            android:layout_marginBottom="20dp"/>

        <RadioGroup
            android:id="@+id/rgPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <RadioButton
                android:id="@+id/rbBangladesh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bangladesh (BDT)"
                android:checked="true"
                android:textColor="#000000"/>
            <RadioButton
                android:id="@+id/rbInternational"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="International (USD)"
                android:layout_marginStart="10dp"
                android:textColor="#000000"/>
        </RadioGroup>

        <LinearLayout
            android:id="@+id/containerPaymentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPaymentInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan with bKash, Nagad, or Rocket to Pay via TallyPay."
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:layout_marginBottom="15dp"/>

            <ImageView
                android:id="@+id/imgQrCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/tallypay_qr" 
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvManualNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or Send Money to: 01701 987 744"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AR ARTS AND COMPUTER"
                android:textSize="14sp"
                android:textStyle="italic"
                android:textColor="#757575"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2: Enter your Transaction ID"
            android:textStyle="bold"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"/>

        <EditText
            android:id="@+id/inputTrxId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#FFFFFF"
            android:hint="Enter TrxID / Reference No."
            android:padding="10dp"
            android:elevation="2dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnSubmitUpgrade"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SUBMIT PAYMENT FOR VERIFICATION"
            android:backgroundTint="#E65100"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
