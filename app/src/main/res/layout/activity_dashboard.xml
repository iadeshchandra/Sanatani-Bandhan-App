<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/header_gradient"
        android:orientation="vertical"
        android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sanatani Bandhan" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Central Management Portal" android:textColor="#FFD180" android:textSize="14sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wisdomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="110dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp" android:background="#FFFFFF">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="VEDIC WISDOM" android:textSize="11sp" android:letterSpacing="0.1"
                android:textStyle="bold" android:textColor="#E65100"/>
            <TextView android:id="@+id/shlokaText" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:text="Loading..." android:textSize="15sp"
                android:textColor="#3E2723" android:textStyle="italic" android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/wisdomCard" android:paddingHorizontal="16dp" android:paddingTop="16dp" android:clipToPadding="false">
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CRM Modules" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="12dp" android:textColor="#424242"/>

            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="2" android:alignmentMode="alignMargins" android:columnOrderPreserved="false">
                
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardMembers"
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#FFF3E0" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Member Info" android:textStyle="bold" android:textColor="#E65100" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/cardDonations"
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#E8F5E9" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹" android:textSize="28sp" android:textStyle="bold" android:textColor="#2E7D32"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smart Chanda" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/cardEvents"
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#FCE4EC" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪔" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Utsav &amp; Seva" android:textStyle="bold" android:textColor="#C2185B" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/cardComms"
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="16dp" app:cardBackgroundColor="#E3F2FD" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mass Sandesh" android:textStyle="bold" android:textColor="#1565C0" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                
            </GridLayout>

            <Button android:id="@+id/btnGenerateReports" android:layout_width="match_parent" android:layout_height="60dp"
                android:layout_marginTop="20dp" android:layout_marginBottom="40dp" android:text="DOWNLOAD FINANCIAL REPORTS"
                android:textStyle="bold" android:backgroundTint="#37474F" app:cornerRadius="12dp"/>
                
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
