<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp" android:background="#FAF9F6">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Mass Sandesh (Broadcast)" android:textSize="26sp" android:textStyle="bold"
        android:textColor="#00838F" android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvMemberCount" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Loading Member Contacts..." android:textSize="14sp" android:textColor="#424242" android:layout_marginBottom="16dp"/>

    <EditText android:id="@+id/inputBroadcastMessage" android:layout_width="match_parent" android:layout_height="150dp"
        android:hint="Type your Mandir announcement here...\n\nExample: Namaskar, there is a committee meeting tomorrow at 8 PM regarding Durga Puja." 
        android:gravity="top|start" android:inputType="textMultiLine" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnSendWhatsApp" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="Broadcast via WhatsApp" android:backgroundTint="#25D366" android:textColor="#FFFFFF" android:layout_marginBottom="12dp"/>
        
    <Button android:id="@+id/btnSendSMS" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="Broadcast via Standard SMS" android:backgroundTint="#1976D2" android:textColor="#FFFFFF"/>

</LinearLayout>
