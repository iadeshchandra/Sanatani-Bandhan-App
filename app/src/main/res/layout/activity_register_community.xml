<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FAF9F6" android:padding="24dp" android:gravity="center">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Register Your Mandir" android:textSize="26sp" android:textStyle="bold" android:textColor="#E65100" android:layout_marginBottom="8dp"/>
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Create a secure CRM workspace for your community" android:textSize="14sp" android:textColor="#757575" android:layout_marginBottom="32dp" android:textAlignment="center"/>

    <EditText android:id="@+id/inputCommunityName" android:layout_width="match_parent" android:layout_height="60dp"
        android:hint="Community/Mandir Name" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="16dp" android:elevation="2dp"/>

    <EditText android:id="@+id/inputAdminEmail" android:layout_width="match_parent" android:layout_height="60dp"
        android:hint="Admin Email Address" android:inputType="textEmailAddress" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="16dp" android:elevation="2dp"/>

    <EditText android:id="@+id/inputAdminPassword" android:layout_width="match_parent" android:layout_height="60dp"
        android:hint="Create Admin Password" android:inputType="textPassword" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="24dp" android:elevation="2dp"/>

    <Button android:id="@+id/btnRegisterWorkspace" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="Create Community Workspace" android:textStyle="bold" android:backgroundTint="#1976D2"/>
</LinearLayout>
